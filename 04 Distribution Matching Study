igh-dimensional sparse feature matrix (n=2 400, d=500)\nmimicking a Bag-of-Words / TF-IDF representation for binary text classification.\n\n- **Class 0** — Topic A (e.g., sports articles)\n- **Class 1** — Topic B (e.g., technology articles)\n\n**Shift mechanism:**  \nTraining contains 80 % Topic-A documents but only 20 % Topic-B, plus the\nfeature space is centred differently.  Test set is perfectly balanced (50/50).\nThis simulates a **label-shift + covariate-shift** scenario common in NLP\n(e.g., a model trained on biased scrapes deployed on a balanced evaluation set).","metadata":{}},{"id":"76bca0b8","cell_type":"code","source":"# ── 1. Create synthetic NLP corpus with distribution shift ────────────────────\nnp.random.seed(42)\n\nN_TOTAL   = 2_400\nN_FEAT    = 500   # simulated vocabulary size (BoW-like)\n\n# Two topics with overlapping centroids (realistic NLP difficulty)\nmu0 = np.random.randn(N_FEAT) * 0.15;  mu0[:30]  += 0.6   # Topic A signal\nmu1 = np.random.randn(N_FEAT) * 0.15;  mu1[20:50] += 0.6  # Topic B signal (overlap with A)\n\ndef make_topic_samples(n, mu, noise=1.2):\n    X = np.random.randn(n, N_FEAT) * noise + mu\n    X = np.maximum(X, 0)                             # TF-IDF non-negative\n    norms = X.sum(axis=1, keepdims=True)\n    X /= (norms + 1e-9)                              # L1-normalise\n    return X\n\nn0, n1 = 1_200, 1_200\nX0 = make_topic_samples(n0, mu0)\nX1 = make_topic_samples(n1, mu1)\nX_nlp = np.vstack([X0, X1])\ny_nlp = np.array([0]*n0 + [1]*n1)\n\n# ── Biased train: 80 % class-0, 20 % class-1\nidx0 = np.where(y_nlp == 0)[0]\nidx1 = np.where(y_nlp == 1)[0]\n\nn_train    = 1_400\nn_tr0      = int(0.80 * n_train)   # 1120 class-0\nn_tr1      = n_train - n_tr0       #  280 class-1\n\ntr0 = np.random.choice(idx0, n_tr0, replace=False)\ntr1 = np.random.choice(idx1, n_tr1, replace=False)\ntrain_idx  = np.concatenate([tr0, tr1])\ntest_idx   = np.setdiff1d(np.arange(N_TOTAL), train_idx)\n\nX_tr_n, y_tr_n = X_nlp[train_idx], y_nlp[train_idx]\nX_te_n, y_te_n = X_nlp[test_idx],  y_nlp[test_idx]\n\n# Oracle: balanced 50/50 train\nor0 = np.random.choice(idx0, n_train//2, replace=False)\nor1 = np.random.choice(idx1, n_train//2, replace=False)\nX_or_n = np.vstack([X_nlp[or0], X_nlp[or1]])\ny_or_n = np.array([0]*(n_train//2) + [1]*(n_train//2))\n\nsc_n = StandardScaler().fit(X_tr_n)\nXtr_n, Xte_n, Xor_n = sc_n.transform(X_tr_n), sc_n.transform(X_te_n), sc_n.transform(X_or_n)\n\nprint(f\"Train class distribution  : {np.bincount(y_tr_n)}\")\nprint(f\"Test  class distribution  : {np.bincount(y_te_n)}\")\nprint(f\"Feature dim               : {X_tr_n.shape[1]}\")","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:21.915683Z","iopub.execute_input":"2026-05-26T07:41:21.916043Z","iopub.status.idle":"2026-05-26T07:41:22.020511Z","shell.execute_reply.started":"2026-05-26T07:41:21.916006Z","shell.execute_reply":"2026-05-26T07:41:22.019559Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Train class distribution  : [1120  280]\nTest  class distribution  : [ 80 920]\nFeature dim               : 500\n","output_type":"stream"}],"execution_count":12},{"id":"3a951fad","cell_type":"code","source":"# ── 2. Visualise NLP shift ────────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 3, figsize=(15, 4))\n\n# (a) Class proportions\nfor ax, (data, lbl, col) in zip(\n        axes[:2],\n        [(y_tr_n, 'Train (Shifted)', '#e74c3c'),\n         (y_te_n, 'Test (Balanced)',  '#3498db')]):\n    counts = np.bincount(data)\n    ax.bar(['Topic A', 'Topic B'], counts / counts.sum() * 100,\n           color=[col, col], alpha=0.75, edgecolor='white', width=0.5)\n    ax.set_ylim(0, 95); ax.set_ylabel('Proportion (%)')\n    ax.set_title(lbl, fontweight='bold')\n    for i, c in enumerate(counts):\n        ax.text(i, counts[i]/counts.sum()*100 + 1.5, f'{c}', ha='center', fontsize=10)\n\n# (b) PCA 2-D of NLP features\npca_n = PCA(n_components=2, random_state=42).fit(np.vstack([Xtr_n, Xte_n]))\nZtr_n = pca_n.transform(Xtr_n); Zte_n = pca_n.transform(Xte_n)\naxes[2].scatter(*Ztr_n[y_tr_n==0].T, s=4, alpha=0.3, c='#e74c3c', label='Train-A')\naxes[2].scatter(*Ztr_n[y_tr_n==1].T, s=4, alpha=0.3, c='#e74c3c', marker='^', label='Train-B')\naxes[2].scatter(*Zte_n[y_te_n==0].T, s=4, alpha=0.3, c='#3498db', label='Test-A')\naxes[2].scatter(*Zte_n[y_te_n==1].T, s=4, alpha=0.3, c='#3498db', marker='^', label='Test-B')\naxes[2].set_title('PCA — Train vs Test Features', fontweight='bold')\naxes[2].legend(markerscale=3, fontsize=8)\n\nplt.suptitle('NLP Dataset — Distribution Shift Overview', fontsize=14,\n             fontweight='bold', y=1.02)\nplt.tight_layout(); plt.show()","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:22.021853Z","iopub.execute_input":"2026-05-26T07:41:22.022217Z","iopub.status.idle":"2026-05-26T07:41:22.693119Z","shell.execute_reply.started":"2026-05-26T07:41:22.02218Z","shell.execute_reply":"2026-05-26T07:41:22.692057Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1950x520 with 3 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":13},{"id":"08c0ac15","cell_type":"code","source":"# ── 3. Baseline & Oracle ──────────────────────────────────────────────────────\nnlp_clf_base = LogisticRegression(max_iter=1000, C=0.5, random_state=42)\nnlp_clf_base.fit(Xtr_n, y_tr_n)\nnlp_results = {}\nnlp_results['Baseline'] = evaluate(nlp_clf_base, Xte_n, y_te_n, binary=True)\n\nnlp_clf_or = LogisticRegression(max_iter=1000, C=0.5, random_state=42)\nnlp_clf_or.fit(Xor_n, y_or_n)\nnlp_results['Oracle'] = evaluate(nlp_clf_or, Xte_n, y_te_n, binary=True)\n\nprint(\"Baseline :\", nlp_results['Baseline'])\nprint(\"Oracle   :\", nlp_results['Oracle'])","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:22.694503Z","iopub.execute_input":"2026-05-26T07:41:22.694927Z","iopub.status.idle":"2026-05-26T07:41:23.084103Z","shell.execute_reply.started":"2026-05-26T07:41:22.694886Z","shell.execute_rep