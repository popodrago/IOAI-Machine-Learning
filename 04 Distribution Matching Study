{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":5,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/mugishapacifique/distribution-matching-study?scriptVersionId=322222617\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"id":"c0ba93fe","cell_type":"markdown","source":"# 📊 Train–Test Distribution Matching\n## A Comprehensive Benchmarking Study Across CV · NLP · Classical ML\n\n> **Covariate shift** occurs when the marginal distribution of features P(X) differs\n> between train and test, while the conditional P(Y|X) stays the same.  \n> This notebook quantifies the damage and shows how **distribution matching** repairs it.\n\n---\n\n### 🗂️ Datasets & Shifts\n\n| Domain | Dataset | Classes | Features | Shift Mechanism |\n|--------|---------|---------|----------|-----------------|\n| 🖼️ **CV** | MNIST Digits (sklearn) | 10 | 64 (8×8 pixels) | Pixel-intensity bias (high-ink sampling) |\n| 📝 **NLP** | Synthetic TF-IDF Corpus | 2 | 500 (sparse BoW) | Topic skew (80/20 class imbalance in train) |\n| 📊 **ML** | Breast Cancer Wisconsin | 2 | 30 continuous | Feature-range selection (large-radius bias) |\n\n### 🔧 Methods Evaluated\n\n| # | Method | Key Idea | Works in High Dims? |\n|---|--------|----------|---------------------|\n| 0 | **Baseline** | No correction | — |\n| 1 | **Discriminative IW (DIW)** | Train/test classifier → weight ratio | ✅ |\n| 2 | **KDE Importance Weighting** | Gaussian KDE density ratio (PCA-reduced) | ⚠️ (low-dim only) |\n| 3 | **Kernel Mean Matching (KMM)** | MMD minimization via QP | ✅ |\n| 4 | **Stratified Resampling** | Histogram-matched bin weights | ✅ |\n| — | **Oracle** | Trained on balanced reference set | — |\n\n---","metadata":{}},{"id":"590f5dee","cell_type":"markdown","source":"## ⚙️ Environment Setup","metadata":{}},{"id":"7a903b25","cell_type":"code","source":"# ── Standard ──────────────────────────────────────────────────────────────────\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport seaborn as sns\nfrom scipy.stats import gaussian_kde\nfrom scipy.spatial.distance import cdist\nfrom scipy.optimize import minimize\n\n# ── Sklearn ───────────────────────────────────────────────────────────────────\nfrom sklearn.datasets import load_digits, load_breast_cancer, make_classification\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.decomposition import PCA\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\nfrom sklearn.metrics import (accuracy_score, f1_score, roc_auc_score,\n                              classification_report)\nimport warnings; warnings.filterwarnings('ignore')\n\n# ── Visual style ──────────────────────────────────────────────────────────────\nplt.rcParams.update({'figure.dpi': 130, 'axes.spines.top': False,\n                     'axes.spines.right': False, 'font.size': 11})\n\nCOLORS = {\n    'Baseline':    '#e74c3c',\n    'DIW':         '#3498db',\n    'KDE':         '#2ecc71',\n    'KMM':         '#9b59b6',\n    'Stratified':  '#f39c12',\n    'Oracle':      '#1abc9c',\n}\n\nnp.random.seed(42)\nprint(\"✅  All libraries loaded.\")","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:16.888829Z","iopub.execute_input":"2026-05-26T07:41:16.889606Z","iopub.status.idle":"2026-05-26T07:41:16.898626Z","shell.execute_reply.started":"2026-05-26T07:41:16.889554Z","shell.execute_reply":"2026-05-26T07:41:16.897509Z"},"trusted":true},"outputs":[{"name":"stdout","text":"✅  All libraries loaded.\n","output_type":"stream"}],"execution_count":2},{"id":"62fb8cf8","cell_type":"markdown","source":"## 🔧 Distribution Matching Implementations","metadata":{}},{"id":"d667c46a","cell_type":"code","source":"# ════════════════════════════════════════════════════════════════════════════\n#  1.  DISCRIMINATIVE IMPORTANCE WEIGHTING (DIW)\n# ════════════════════════════════════════════════════════════════════════════\ndef discriminative_iw(X_train, X_test, clip=10.0):\n    # Train a logistic classifier to separate train from test.\n    # w(x) = P_test(x)/P_train(x) ~= p/(1-p) * n_tr/n_te\n    n_tr, n_te = len(X_train), len(X_test)\n    X_all = np.vstack([X_train, X_test])\n    y_dom = np.array([0]*n_tr + [1]*n_te)\n    clf = LogisticRegression(max_iter=1000, C=0.5)\n    clf.fit(X_all, y_dom)\n    p = clf.predict_proba(X_train)[:, 1]          # P(test | x) for train pts\n    w = (p / (1 - p + 1e-9)) * (n_tr / n_te)\n    w = np.clip(w, 0, clip)\n    return w / w.mean()\n\n\n# ════════════════════════════════════════════════════════════════════════════\n#  2.  KDE IMPORTANCE WEIGHTING\n# ════════════════════════════════════════════════════════════════════════════\ndef kde_iw(X_train, X_test, n_pca=3, clip=10.0):\n    # Gaussian KDE density ratio in PCA-reduced space.\n    # Limited to low-dimensional projections to avoid the curse of dimensionality.\n    k = min(n_pca, X_train.shape[1])\n    pca = PCA(n_components=k, random_state=42)\n    pca.fit(np.vstack([X_train, X_test]))\n    Ztr = pca.transform(X_train)\n    Zte = pca.transform(X_test)\n\n    kde_tr = gaussian_kde(Ztr.T, bw_method='scott')\n    kde_te = gaussian_kde(Zte.T, bw_method='scott')\n\n    p_tr = kde_tr(Ztr.T) + 1e-12\n    p_te = kde_te(Ztr.T) + 1e-12\n    w = p_te / p_tr\n    w = np.clip(w, 0, clip)\n    return w / w.mean()\n\n\n# ════════════════════════════════════════════════════════════════════════════\n#  3.  KERNEL MEAN MATCHING  (KMM / MMD minimisation)\n# ════════════════════════════════════════════════════════════════════════════\ndef kmm_iw(X_train, X_test, B=10.0, max_sub=250, sigma=None):\n    # Solves the QP:\n    # min_w   1/2 * w^T K w  -  kappa^T w\n    # s.t.    0 <= w_i <= B,   |sum(w)/n - 1| <= eps\n    # where K_ij = k(x_i, x_j) and kappa_i = (n/m) sum_j k(x_i, z_j).\n    n = len(X_train); m = len(X_test)\n    idx_tr = np.random.choice(n, min(max_sub, n), replace=False)\n    idx_te = np.random.choice(m, min(max_sub, m), replace=False)\n    Xtr = X_train[idx_tr]; Xte = X_test[idx_te]\n    ns  = len(Xtr)\n\n    if sigma is None:\n        D = cdist(Xtr[:80], Xtr[:80])\n        sigma = np.median(D[D > 0]) if D[D > 0].size > 0 else 1.0\n\n    def rbf(A, B_):\n        return np.exp(-cdist(A, B_, 'sqeuclidean') / (2 * sigma**2))\n\n    K     = rbf(Xtr, Xtr)\n    kappa = rbf(Xtr, Xte).mean(axis=1) * ns\n\n    eps   = ns / np.sqrt(ns)\n    res   = minimize(\n        lambda w: 0.5 * w @ K @ w - kappa @ w,\n        np.ones(ns),\n        jac    = lambda w: K @ w - kappa,\n        bounds = [(0, B)] * ns,\n        constraints = [{'type': 'ineq',\n                         'fun': lambda w: eps - abs(w.sum() - ns)}],\n        method = 'SLSQP',\n        options = {'maxiter': 300, 'ftol': 1e-6},\n    )\n    full_w = np.ones(n)\n    full_w[idx_tr] = np.maximum(res.x, 0)\n    return full_w / full_w.mean()\n\n\n# ════════════════════════════════════════════════════════════════════════════\n#  4.  STRATIFIED / HISTOGRAM RESAMPLING\n# ════════════════════════════════════════════════════════════════════════════\ndef stratified_iw(X_train, X_test, n_bins=12):\n    # Project onto first PCA axis, build histograms for train & test,\n    # and weight each training sample by the density ratio in its bin.\n    pca1 = PCA(n_components=1, random_state=42)\n    pca1.fit(np.vstack([X_train, X_test]))\n    ztr = pca1.transform(X_train).ravel()\n    zte = pca1.transform(X_test).ravel()\n\n    lo, hi = min(ztr.min(), zte.min()), max(ztr.max(), zte.max())\n    bins = np.linspace(lo, hi, n_bins + 1)\n\n    cnt_tr, _ = np.histogram(ztr, bins=bins)\n    cnt_te, _ = np.histogram(zte, bins=bins)\n\n    p_tr = cnt_tr / (cnt_tr.sum() + 1e-12)\n    p_te = cnt_te / (cnt_te.sum() + 1e-12)\n    ratio = np.where(p_tr > 1e-8, p_te / (p_tr + 1e-8), 0.0)\n\n    bidx = np.clip(np.digitize(ztr, bins[1:-1]), 0, n_bins - 1)\n    w    = ratio[bidx]\n    w    = np.clip(w, 0, 10)\n    return w / (w.mean() + 1e-12)\n\n\n# ════════════════════════════════════════════════════════════════════════════\n#  EVALUATION HELPER\n# ════════════════════════════════════════════════════════════════════════════\ndef evaluate(clf, X_te, y_te, binary=False):\n    yp  = clf.predict(X_te)\n    avg = 'binary' if binary else 'macro'\n    out = {\n        'Accuracy': round(accuracy_score(y_te, yp), 4),\n        'F1':       round(f1_score(y_te, yp, average=avg, zero_division=0), 4),\n    }\n    if binary and hasattr(clf, 'predict_proba'):\n        try:\n            pp = clf.predict_proba(X_te)[:, 1]\n            out['AUC'] = round(roc_auc_score(y_te, pp), 4)\n        except Exception:\n            pass\n    return out\n\n\ndef fit_weighted(X_tr, y_tr, w, clf_cls=LogisticRegression, **kw):\n    clf = clf_cls(**kw)\n    clf.fit(X_tr, y_tr, sample_weight=w)\n    return clf\n\n\nprint(\"✅  All methods defined:  DIW | KDE-IW | KMM | Stratified\")","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:16.900454Z","iopub.execute_input":"2026-05-26T07:41:16.90084Z","iopub.status.idle":"2026-05-26T07:41:16.927635Z","shell.execute_reply.started":"2026-05-26T07:41:16.900813Z","shell.execute_reply":"2026-05-26T07:41:16.926699Z"},"trusted":true},"outputs":[{"name":"stdout","text":"✅  All methods defined:  DIW | KDE-IW | KMM | Stratified\n","output_type":"stream"}],"execution_count":3},{"id":"6eb719c6","cell_type":"markdown","source":"---\n# 🖼️ Part 1 — Computer Vision: MNIST Digits\n\n**Dataset:** sklearn's `load_digits` — 1 797 samples of 8×8 pixel handwritten digits (classes 0–9).\n\n**Shift mechanism:**  \nTraining is biased toward *high-ink* digits (the top 70 % by total pixel brightness).\nThe test set is a balanced random hold-out.  \nThis mimics real-world drift where a scanner/camera that was set to capture\nbold/dark strokes was used for training, but production samples vary widely.","metadata":{}},{"id":"8440fa57","cell_type":"code","source":"# ── 1. Load & create distribution shift ───────────────────────────────────────\ndigits  = load_digits()\nX_raw, y_raw = digits.data.astype(float), digits.target   # 1797 x 64\n\nnp.random.seed(42)\nink      = X_raw.sum(axis=1)                               # \"ink level\" per image\nink_med  = np.percentile(ink, 35)                          # threshold\n\nhi_idx = np.where(ink >= ink_med)[0]                       # bold strokes\nlo_idx = np.where(ink <  ink_med)[0]                       # faint strokes\n\n# Biased train: 80 % high-ink, 20 % low-ink\nn_train        = 1_100\nn_train_hi     = int(0.80 * n_train)\nn_train_lo     = n_train - n_train_hi\n\ntrain_hi       = np.random.choice(hi_idx, n_train_hi, replace=False)\ntrain_lo       = np.random.choice(lo_idx, n_train_lo, replace=False)\ntrain_idx      = np.concatenate([train_hi, train_lo])\n\nall_idx        = np.arange(len(X_raw))\ntest_idx       = np.setdiff1d(all_idx, train_idx)\n\nX_tr, y_tr     = X_raw[train_idx], y_raw[train_idx]\nX_te, y_te     = X_raw[test_idx],  y_raw[test_idx]\n\n# Oracle: balanced random train split\noracle_idx     = np.random.choice(all_idx, n_train, replace=False)\nX_or, y_or     = X_raw[oracle_idx], y_raw[oracle_idx]\n\n# Scale\nscaler         = StandardScaler().fit(X_tr)\nXtr_s, Xte_s   = scaler.transform(X_tr), scaler.transform(X_te)\nXor_s          = scaler.transform(X_or)\n\nprint(f\"Train : {len(X_tr)} samples  |  Test : {len(X_te)} samples\")\nprint(f\"Train ink mean : {ink[train_idx].mean():.1f}  |  \"\n      f\"Test ink mean  : {ink[test_idx].mean():.1f}   (shift confirmed)\")","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:16.928731Z","iopub.execute_input":"2026-05-26T07:41:16.929083Z","iopub.status.idle":"2026-05-26T07:41:16.984119Z","shell.execute_reply.started":"2026-05-26T07:41:16.929057Z","shell.execute_reply":"2026-05-26T07:41:16.98318Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Train : 1100 samples  |  Test : 697 samples\nTrain ink mean : 321.1  |  Test ink mean  : 299.2   (shift confirmed)\n","output_type":"stream"}],"execution_count":4},{"id":"ab96ecf5","cell_type":"code","source":"# ── 2. Visualise the shift ────────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 3, figsize=(15, 4))\n\n# (a) Ink distribution\naxes[0].hist(ink[train_idx], bins=40, alpha=0.6, color='#e74c3c', label='Train')\naxes[0].hist(ink[test_idx],  bins=40, alpha=0.6, color='#3498db', label='Test')\naxes[0].set_title('Pixel-Ink Distribution (Feature Shift)', fontweight='bold')\naxes[0].set_xlabel('Total pixel brightness'); axes[0].set_ylabel('Count')\naxes[0].legend()\n\n# (b) PCA 2-D scatter\npca2 = PCA(n_components=2, random_state=42).fit(np.vstack([Xtr_s, Xte_s]))\nZtr  = pca2.transform(Xtr_s)\nZte  = pca2.transform(Xte_s)\naxes[1].scatter(Ztr[:, 0], Ztr[:, 1], s=5, alpha=0.4, c='#e74c3c', label='Train')\naxes[1].scatter(Zte[:, 0], Zte[:, 1], s=5, alpha=0.4, c='#3498db', label='Test')\naxes[1].set_title('PCA Space — Train vs Test', fontweight='bold')\naxes[1].set_xlabel('PC-1'); axes[1].set_ylabel('PC-2')\naxes[1].legend()\n\n# (c) Per-class sample counts\ntr_cnt = np.bincount(y_tr, minlength=10)\nte_cnt = np.bincount(y_te, minlength=10)\nx_ = np.arange(10)\naxes[2].bar(x_-0.2, tr_cnt, 0.4, color='#e74c3c', alpha=0.8, label='Train')\naxes[2].bar(x_+0.2, te_cnt, 0.4, color='#3498db', alpha=0.8, label='Test')\naxes[2].set_title('Class Distribution', fontweight='bold')\naxes[2].set_xlabel('Digit class'); axes[2].set_ylabel('Count'); axes[2].legend()\n\nplt.suptitle('CV Dataset — Distribution Shift Overview', fontsize=14, fontweight='bold', y=1.02)\nplt.tight_layout(); plt.show()","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:16.986012Z","iopub.execute_input":"2026-05-26T07:41:16.986371Z","iopub.status.idle":"2026-05-26T07:41:17.771716Z","shell.execute_reply.started":"2026-05-26T07:41:16.986345Z","shell.execute_reply":"2026-05-26T07:41:17.770856Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1950x520 with 3 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":5},{"id":"6db196fb","cell_type":"code","source":"# ── 3. Baseline (no correction) ───────────────────────────────────────────────\nbase_clf = LogisticRegression(max_iter=1000, C=1.0, random_state=42)\nbase_clf.fit(Xtr_s, y_tr)\ncv_results = {}\ncv_results['Baseline'] = evaluate(base_clf, Xte_s, y_te)\n\noracle_clf = LogisticRegression(max_iter=1000, C=1.0, random_state=42)\noracle_clf.fit(Xor_s, y_or)\ncv_results['Oracle'] = evaluate(oracle_clf, Xte_s, y_te)\n\nprint(\"Baseline  :\", cv_results['Baseline'])\nprint(\"Oracle    :\", cv_results['Oracle'])","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:17.772928Z","iopub.execute_input":"2026-05-26T07:41:17.773332Z","iopub.status.idle":"2026-05-26T07:41:17.989289Z","shell.execute_reply.started":"2026-05-26T07:41:17.773305Z","shell.execute_reply":"2026-05-26T07:41:17.985861Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Baseline  : {'Accuracy': 0.9498, 'F1': 0.9472}\nOracle    : {'Accuracy': 0.9828, 'F1': 0.9823}\n","output_type":"stream"}],"execution_count":6},{"id":"31da8131","cell_type":"code","source":"# ── 4a. Method 1 — Discriminative Importance Weighting ───────────────────────\nw_diw  = discriminative_iw(Xtr_s, Xte_s)\nclf_d  = fit_weighted(Xtr_s, y_tr, w_diw,\n                      clf_cls=LogisticRegression, max_iter=1000, C=1.0, random_state=42)\ncv_results['DIW'] = evaluate(clf_d, Xte_s, y_te)\n\n# Weight distribution insight\nfig, ax = plt.subplots(figsize=(7, 3))\nax.hist(w_diw, bins=50, color='#3498db', edgecolor='white', alpha=0.85)\nax.axvline(1.0, color='k', ls='--', lw=1.5, label='Uniform (=1)')\nax.set_title('DIW Weight Distribution (CV)', fontweight='bold')\nax.set_xlabel('Sample weight'); ax.set_ylabel('Count'); ax.legend()\nplt.tight_layout(); plt.show()\n\nprint(\"DIW  :\", cv_results['DIW'])","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:17.990565Z","iopub.execute_input":"2026-05-26T07:41:17.990909Z","iopub.status.idle":"2026-05-26T07:41:18.588007Z","shell.execute_reply.started":"2026-05-26T07:41:17.990875Z","shell.execute_reply":"2026-05-26T07:41:18.587071Z"},"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 910x390 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"DIW  : {'Accuracy': 0.944, 'F1': 0.941}\n","output_type":"stream"}],"execution_count":7},{"id":"e5f66a4d","cell_type":"code","source":"# ── 4b. Method 2 — KDE Importance Weighting ──────────────────────────────────\nw_kde  = kde_iw(Xtr_s, Xte_s, n_pca=3)\nclf_k  = fit_weighted(Xtr_s, y_tr, w_kde,\n                      clf_cls=LogisticRegression, max_iter=1000, C=1.0, random_state=42)\ncv_results['KDE'] = evaluate(clf_k, Xte_s, y_te)\nprint(\"KDE  :\", cv_results['KDE'])","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:18.589544Z","iopub.execute_input":"2026-05-26T07:41:18.589919Z","iopub.status.idle":"2026-05-26T07:41:18.815091Z","shell.execute_reply.started":"2026-05-26T07:41:18.58989Z","shell.execute_reply":"2026-05-26T07:41:18.812273Z"},"trusted":true},"outputs":[{"name":"stdout","text":"KDE  : {'Accuracy': 0.9512, 'F1': 0.9486}\n","output_type":"stream"}],"execution_count":8},{"id":"7502d41e","cell_type":"code","source":"# ── 4c. Method 3 — Kernel Mean Matching (KMM) ────────────────────────────────\n# Project to 20 PCA dims first to speed up QP\npca20  = PCA(n_components=20, random_state=42).fit(np.vstack([Xtr_s, Xte_s]))\nXtr_20 = pca20.transform(Xtr_s)\nXte_20 = pca20.transform(Xte_s)\n\nw_kmm  = kmm_iw(Xtr_20, Xte_20, B=8.0, max_sub=200)\nclf_m  = fit_weighted(Xtr_s, y_tr, w_kmm,\n                      clf_cls=LogisticRegression, max_iter=1000, C=1.0, random_state=42)\ncv_results['KMM'] = evaluate(clf_m, Xte_s, y_te)\nprint(\"KMM  :\", cv_results['KMM'])","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:18.817551Z","iopub.execute_input":"2026-05-26T07:41:18.820996Z","iopub.status.idle":"2026-05-26T07:41:21.227121Z","shell.execute_reply.started":"2026-05-26T07:41:18.82096Z","shell.execute_reply":"2026-05-26T07:41:21.226118Z"},"trusted":true},"outputs":[{"name":"stdout","text":"KMM  : {'Accuracy': 0.9469, 'F1': 0.9441}\n","output_type":"stream"}],"execution_count":9},{"id":"c9514335","cell_type":"code","source":"# ── 4d. Method 4 — Stratified Resampling ────────────────────────────────────\nw_str  = stratified_iw(Xtr_s, Xte_s, n_bins=14)\nclf_s  = fit_weighted(Xtr_s, y_tr, w_str,\n                      clf_cls=LogisticRegression, max_iter=1000, C=1.0, random_state=42)\ncv_results['Stratified'] = evaluate(clf_s, Xte_s, y_te)\nprint(\"Stratified :\", cv_results['Stratified'])","metadata":{"execution":{"iopub.status.busy":"2026-05-26T07:41:21.23033Z","iopub.execute_input":"2026-05-26T07:41:21.230742Z","iopub.status.idle":"2026-05-26T07:41:21.459834Z","shell.execute_reply.started":"2026-05-26T07:41:21.230687Z","shell.execute_reply":"2026-05-26T07:41:21.456838Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Stratified : {'Accuracy': 0.9512, 'F1': 0.9486}\n","output_type":"stream"}],"execution_count":10},{"id":"c049ab37","cell_type":"code","source":"# ── 5. CV Results Summary ─────────────────────────────────────────────────────\ncv_df = pd.DataFrame(cv_results).T.reset_index().rename(columns={'index': 'Method'})\nprint(\"